#!/usr/bin/env bash

set -uo pipefail

OUTPUT_JSON=false
STATE_FILE=".fss-state.yaml"
DOMAIN=""
DATA_ROOT=""
CLOUDFLARE_TOKEN="${CF_API_TOKEN:-${CLOUDFLARE_API_TOKEN:-}}"

OK_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0
CHECK_NAMES=()
CHECK_STATUSES=()
CHECK_BLOCKING=()
CHECK_MESSAGES=()

usage() {
  cat <<'USAGE'
Usage: scripts/fayaasrv-doctor [--json] [--state <path>] [--domain <domain>] [--data-root <path>]

Runs FayaaSRV host preflight checks. Set CF_API_TOKEN or CLOUDFLARE_API_TOKEN
to verify the Cloudflare token before tunnel/DNS work.
USAGE
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

json_escape() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//"/\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

state_value() {
  local key="$1"
  [[ -f "$STATE_FILE" ]] || return 1
  awk -F: -v wanted="$key" '
    $1 == wanted {
      value=$0
      sub("^[^:]*:", "", value)
      sub("^[[:space:]]*", "", value)
      sub("[[:space:]]*$", "", value)
      gsub(/^"|"$/, "", value)
      print value
      exit
    }
  ' "$STATE_FILE"
}

add_check() {
  local status="$1"
  local name="$2"
  local blocking="$3"
  local message="$4"

  CHECK_STATUSES+=("$status")
  CHECK_NAMES+=("$name")
  CHECK_BLOCKING+=("$blocking")
  CHECK_MESSAGES+=("$message")

  case "$status" in
    ok) OK_COUNT=$((OK_COUNT + 1)) ;;
    warn) WARN_COUNT=$((WARN_COUNT + 1)) ;;
    fail) FAIL_COUNT=$((FAIL_COUNT + 1)) ;;
  esac

  if [[ "$OUTPUT_JSON" != true ]]; then
    printf '[%s] %s: %s\n' "$status" "$name" "$message"
  fi
}

emit_json() {
  local ok_value=false
  [[ "$FAIL_COUNT" -eq 0 ]] && ok_value=true

  printf '{"ok":%s,"summary":{"ok":%d,"warn":%d,"fail":%d},"checks":[' "$ok_value" "$OK_COUNT" "$WARN_COUNT" "$FAIL_COUNT"

  local index
  for index in "${!CHECK_NAMES[@]}"; do
    if [[ "$index" -gt 0 ]]; then
      printf ','
    fi
    printf '{"name":"%s","status":"%s","blocking":%s,"message":"%s"}' \
      "$(json_escape "${CHECK_NAMES[$index]}")" \
      "$(json_escape "${CHECK_STATUSES[$index]}")" \
      "${CHECK_BLOCKING[$index]}" \
      "$(json_escape "${CHECK_MESSAGES[$index]}")"
  done

  printf ']}\n'
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --json)
        OUTPUT_JSON=true
        shift
        ;;
      --state)
        [[ "$#" -ge 2 ]] || { printf 'missing value for --state\n' >&2; exit 2; }
        STATE_FILE="$2"
        shift 2
        ;;
      --domain)
        [[ "$#" -ge 2 ]] || { printf 'missing value for --domain\n' >&2; exit 2; }
        DOMAIN="$2"
        shift 2
        ;;
      --data-root)
        [[ "$#" -ge 2 ]] || { printf 'missing value for --data-root\n' >&2; exit 2; }
        DATA_ROOT="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf 'unknown argument: %s\n' "$1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done
}

init_context() {
  if [[ -z "$DOMAIN" ]]; then
    DOMAIN="$(state_value domain 2>/dev/null || true)"
  fi
  if [[ -z "$DATA_ROOT" ]]; then
    DATA_ROOT="$(state_value data_root 2>/dev/null || true)"
  fi
  if [[ -z "$DATA_ROOT" ]]; then
    if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
      DATA_ROOT="$HOME/srv"
    else
      DATA_ROOT="/srv"
    fi
  fi
}

normalize_arch() {
  case "$1" in
    x86_64|amd64) printf 'amd64' ;;
    aarch64|arm64) printf 'arm64' ;;
    *) return 1 ;;
  esac
}

check_os() {
  local kernel
  kernel="$(uname -s 2>/dev/null || true)"

  if [[ "$kernel" == "Darwin" ]]; then
    add_check ok os true "Mac detected"
    return
  fi

  if [[ "$kernel" != "Linux" ]]; then
    add_check fail os true "unsupported OS: ${kernel:-unknown}"
    return
  fi

  local distro=""
  local version=""
  if command_exists lsb_release; then
    distro="$(lsb_release -is 2>/dev/null || true)"
    version="$(lsb_release -rs 2>/dev/null || true)"
  elif [[ -r /etc/os-release ]]; then
    distro="$(. /etc/os-release && printf '%s' "${ID:-}")"
    version="$(. /etc/os-release && printf '%s' "${VERSION_ID:-}")"
  fi

  local distro_lower
  distro_lower="$(printf '%s' "$distro" | tr '[:upper:]' '[:lower:]')"
  if [[ "$distro_lower" == "ubuntu" ]]; then
    add_check ok os true "Ubuntu ${version:-unknown} detected"
  else
    add_check fail os true "Linux distro must be Ubuntu for the documented helper path; found ${distro:-unknown}"
  fi
}

check_arch() {
  local raw normalized
  raw="$(uname -m 2>/dev/null || true)"
  if normalized="$(normalize_arch "$raw" 2>/dev/null)"; then
    add_check ok architecture false "$normalized ($raw)"
  else
    add_check fail architecture false "unsupported architecture: ${raw:-unknown}; expected amd64 or arm64"
  fi
}

check_ram() {
  local mb=""
  if [[ -r /proc/meminfo ]]; then
    mb="$(awk '/MemTotal:/ { printf "%d", $2 / 1024 }' /proc/meminfo)"
  elif command_exists sysctl; then
    local bytes
    bytes="$(sysctl -n hw.memsize 2>/dev/null || true)"
    if [[ "$bytes" =~ ^[0-9]+$ ]]; then
      mb=$((bytes / 1024 / 1024))
    fi
  fi

  if [[ -z "$mb" ]]; then
    add_check warn ram false "could not determine RAM"
  elif [[ "$mb" -lt 2048 ]]; then
    add_check fail ram false "${mb} MB available; minimum is 2048 MB"
  elif [[ "$mb" -lt 4096 ]]; then
    add_check warn ram false "${mb} MB available; 4 GB or more is recommended"
  else
    add_check ok ram false "${mb} MB available"
  fi
}

existing_path_for_df() {
  local path="$1"
  while [[ ! -e "$path" && "$path" != "/" ]]; do
    path="$(dirname "$path")"
  done
  printf '%s' "$path"
}

check_disk() {
  local probe free_kb free_gb
  probe="$(existing_path_for_df "$DATA_ROOT")"
  free_kb="$(df -Pk "$probe" 2>/dev/null | awk 'NR == 2 { print $4 }')"

  if [[ -z "$free_kb" ]]; then
    add_check warn disk false "could not determine free space for ${DATA_ROOT}"
    return
  fi

  free_gb=$((free_kb / 1024 / 1024))
  if [[ "$free_gb" -lt 20 ]]; then
    add_check warn disk false "${free_gb} GB free at ${probe}; 20 GB or more is recommended for ${DATA_ROOT}"
  else
    add_check ok disk false "${free_gb} GB free at ${probe}"
  fi
}

docker_container_running() {
  local name="$1"
  command_exists docker || return 1
  docker ps --filter "name=^/${name}$" --format '{{.Names}}' 2>/dev/null | grep -qx "$name"
}

docker_container_publishes_port() {
  local name="$1"
  local port="$2"
  command_exists docker || return 1
  docker ps --filter "name=^/${name}$" --format '{{.Names}} {{.Ports}}' 2>/dev/null | grep -Eq "^${name} .*(:|->)${port}(/|->|$)|^${name} .*:${port}->"
}

check_docker() {
  if ! command_exists docker; then
    add_check fail docker true "docker command is missing"
    return
  fi

  if docker info >/dev/null 2>&1; then
    add_check ok docker true "daemon is reachable"
  else
    add_check fail docker true "docker command exists but daemon is not reachable"
  fi
}

check_compose() {
  if ! command_exists docker; then
    add_check fail compose true "docker command is missing"
    return
  fi

  local version
  version="$(docker compose version 2>/dev/null || true)"
  if [[ -n "$version" ]]; then
    add_check ok compose true "$version"
  else
    add_check fail compose true "Docker Compose v2 is not available through 'docker compose'"
  fi
}

port_listeners() {
  local port="$1"
  if command_exists ss; then
    ss -H -ltnp "sport = :${port}" 2>/dev/null || true
  elif command_exists lsof; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null || true
  else
    return 2
  fi
}

check_public_ports() {
  local failures=0
  local messages=()
  local port listeners

  for port in 80 443; do
    listeners="$(port_listeners "$port")"
    if [[ "$?" -eq 2 ]]; then
      add_check warn public_ports true "neither ss nor lsof is available to inspect ports 80/443"
      return
    fi

    if [[ -z "$listeners" ]]; then
      messages+=("${port}=free")
      continue
    fi

    if printf '%s\n' "$listeners" | grep -Eiq 'caddy' || docker_container_publishes_port caddy "$port"; then
      messages+=("${port}=owned by caddy")
    else
      messages+=("${port}=conflict")
      failures=$((failures + 1))
    fi
  done

  if [[ "$failures" -eq 0 ]]; then
    add_check ok public_ports true "${messages[*]}"
  else
    add_check fail public_ports true "ports 80/443 must be free or owned by FayaaSRV caddy; ${messages[*]}"
  fi
}

check_ssh_port() {
  local listeners
  listeners="$(port_listeners 22)"
  if [[ "$?" -eq 2 ]]; then
    add_check warn ssh_port false "neither ss nor lsof is available to inspect port 22"
  elif [[ -n "$listeners" ]]; then
    add_check ok ssh_port false "port 22 has a listener"
  else
    add_check warn ssh_port false "port 22 is not listening; SSH over Cloudflare will not work until SSH is enabled"
  fi
}

check_domain_dns() {
  if [[ -z "$DOMAIN" || "$DOMAIN" == "null" ]]; then
    add_check warn dns false "domain is not recorded yet"
    return
  fi

  if ! command_exists dig; then
    add_check warn dns false "dig is not installed; cannot resolve ${DOMAIN}"
    return
  fi

  local result
  result="$( { dig +short "$DOMAIN" A 2>/dev/null; dig +short "$DOMAIN" AAAA 2>/dev/null; } | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
  if [[ -n "$result" ]]; then
    add_check ok dns false "${DOMAIN} resolves: ${result}"
  else
    add_check warn dns false "${DOMAIN} does not currently resolve"
  fi
}

check_cloudflare_token() {
  if [[ -z "$CLOUDFLARE_TOKEN" ]]; then
    add_check warn cloudflare_token false "set CF_API_TOKEN to verify Cloudflare token validity before Step 40"
    return
  fi

  if ! command_exists curl; then
    add_check warn cloudflare_token false "curl is missing; cannot verify Cloudflare token"
    return
  fi

  local response
  response="$(curl -fsS --max-time 10 -H "Authorization: Bearer ${CLOUDFLARE_TOKEN}" https://api.cloudflare.com/client/v4/user/tokens/verify 2>/dev/null || true)"
  if printf '%s' "$response" | grep -q '"success":true'; then
    add_check ok cloudflare_token false "Cloudflare token is valid; DNS and tunnel permissions are exercised in Step 40"
  else
    add_check warn cloudflare_token false "Cloudflare token verification failed or returned an unexpected response"
  fi
}

check_conflicts() {
  local conflicts=()
  local service

  if command_exists systemctl; then
    for service in nginx apache2 httpd postgresql; do
      if systemctl is-active --quiet "$service" 2>/dev/null; then
        conflicts+=("active systemd service: ${service}")
      fi
    done
  fi

  local pg_listeners
  pg_listeners="$(port_listeners 5432)"
  if [[ -n "$pg_listeners" ]] && docker_container_running postgres; then
    true
  elif [[ -n "$pg_listeners" ]] && ! printf '%s\n' "$pg_listeners" | grep -Eiq 'docker|postgres'; then
    conflicts+=("port 5432 listener is not clearly FayaaSRV postgres")
  elif [[ -n "$pg_listeners" ]]; then
    conflicts+=("port 5432 is already listening before the FayaaSRV postgres container is running")
  fi

  if [[ "${#conflicts[@]}" -eq 0 ]]; then
    add_check ok conflicts false "no obvious nginx/apache/host-postgres conflicts found"
  else
    add_check warn conflicts false "$(IFS='; '; printf '%s' "${conflicts[*]}")"
  fi
}

check_firewall() {
  if command_exists ufw; then
    local status
    status="$(ufw status 2>/dev/null | head -n 1 || true)"
    add_check ok firewall false "${status:-ufw installed, status unavailable}"
  elif command_exists iptables; then
    add_check ok firewall false "iptables is available; review host rules if public ports are blocked"
  else
    add_check warn firewall false "no ufw or iptables command found"
  fi
}

main() {
  parse_args "$@"
  init_context

  check_os
  check_arch
  check_ram
  check_disk
  check_docker
  check_compose
  check_public_ports
  check_ssh_port
  check_domain_dns
  check_cloudflare_token
  check_conflicts
  check_firewall

  if [[ "$OUTPUT_JSON" == true ]]; then
    emit_json
  else
    printf 'doctor: %d ok, %d warn, %d fail\n' "$OK_COUNT" "$WARN_COUNT" "$FAIL_COUNT"
  fi

  if [[ "$FAIL_COUNT" -gt 0 ]]; then
    exit 1
  fi
}

main "$@"
