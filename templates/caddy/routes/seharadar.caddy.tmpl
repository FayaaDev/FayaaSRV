	# SehaRadar - AI-powered health surveillance automation
	# Supports seha-radar.{{DOMAIN}} (primary) and legacy domains for webhook compatibility
	@seharadar host seha-radar.{{DOMAIN}} health-agents.{{DOMAIN}} phn-agents.{{DOMAIN}}
	handle @seharadar {
		# All routes handled by SehaRadar service (dashboards, APIs, webhooks)
		reverse_proxy seha-radar:8080 {
			header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
			header_up X-Real-IP {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
		}
	}
