services:
  dbhub:
    image: bytebase/dbhub:latest
    container_name: dbhub
    restart: unless-stopped
    env_file:
      - .env
    command:
      - --transport
      - http
      - --port
      - "8080"
      - --config
      - /app/config/dbhub.toml
    ports:
      - "127.0.0.1:5009:8080"
    volumes:
      - {{DATA_ROOT}}/docker/dbhub/dbhub.toml:/app/config/dbhub.toml:ro
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ["CMD", "wget", "-q", "-O-", "http://127.0.0.1:8080/healthz"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 20s

networks:
  {{DOCKER_NET}}:
    external: true
