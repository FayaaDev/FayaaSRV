services:
  n8n:
    build:
      context: .
      dockerfile: Dockerfile
    image: n8n-custom:latest
    container_name: n8n
    restart: unless-stopped
    env_file:
      - .env
    environment:
      - NODES_EXCLUDE=[]
    volumes:
      - {{DATA_ROOT}}/data/n8n/n8n:/home/node/.n8n
      - {{DATA_ROOT}}/data/n8n/n8nworkflows:/home/node/workflows
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ['CMD', 'wget', '--spider', '-q', 'http://localhost:5678/healthz']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

networks:
  {{DOCKER_NET}}:
    external: true
