# Immich photo and video library — protected by Authentik forward auth
	{% import "_authentik-protected-route.caddy.tmpl" as authentik %}
	{% call authentik.protected_route("immich", IMMICH_SUBDOMAIN ~ "." ~ DOMAIN, "immich-server:2283") %}
		header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
		header_up X-Real-IP {http.request.header.CF-Connecting-IP}
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
	{% endcall %}
