services:
  actual-budget:
    image: ${ACTUAL_BUDGET_IMAGE:-actualbudget/actual-server:latest}
    container_name: actual-budget
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - {{DATA_ROOT}}/data/actual-budget:/data
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      test: ["CMD-SHELL", "node src/scripts/health-check.js"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 20s

networks:
  {{DOCKER_NET}}:
    external: true
