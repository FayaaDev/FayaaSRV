# Vaultwarden configuration.
# Upstream recommends setting DOMAIN when running behind a reverse proxy so
# generated links/attachments use https correctly.

# Public base URL for this instance (must include scheme).
DOMAIN=https://{{VAULTWARDEN_SUBDOMAIN}}.{{DOMAIN}}

# Create your first user, then set to false to prevent public signups.
SIGNUPS_ALLOWED=true

# Optional but strongly recommended: protects the /admin page.
# Generate with e.g.: openssl rand -base64 48
ADMIN_TOKEN={{VAULTWARDEN_ADMIN_TOKEN}}

# Optional: reduce resource usage by disabling websocket notifications.
# WebSockets are enabled by default upstream.
ENABLE_WEBSOCKET=true
